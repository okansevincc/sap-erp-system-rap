projection;
strict ( 2 );
use draft;

define behavior for ZFAB_C_SO_HDR alias Sales
{
  use create;
  use update;
  use delete;

  use action Activate;
  use action Discard;
  use action Edit;
  use action Resume;
  use action Prepare;

  use association _SalesItems { create; with draft; }
}

define behavior for ZFAB_C_SO_ITM alias SalesItems
{
  use update;
  use delete;

  use association _Sales { with draft; }
}